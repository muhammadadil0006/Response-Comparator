# .env.sample — commit this file (no real values)

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_playground"

# Auth secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="generate-with-openssl-rand-base64-32"
JWT_REFRESH_SECRET="generate-with-openssl-rand-base64-32"

# AI API keys (Vercel AI Gateway — single key for all providers)
AI_GATEWAY_API_KEY="your-ai-gateway-api-key"

# Public (safe to expose to browser — must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Runtime
NODE_ENV="development"

# Vercel system variables (auto-populated on Vercel, useful for local reference)
# VERCEL_ENV=development|preview|production
# VERCEL_URL=<deployment-url-without-protocol>
# VERCEL_REGION=iad1
